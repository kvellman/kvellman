# Copy to .env for local overrides. The dev defaults below match docker-compose.dev.yml,
# so for local dev you can run without a .env at all.
DATABASE_URL=postgres://kvellman:kvellman@localhost:5440/kvellman
REPO_URL=http://localhost:3000

# Session cookie sealing secret for nuxt-auth-utils (>=32 chars). REQUIRED in production;
# generate with: openssl rand -hex 32
NUXT_SESSION_PASSWORD=change-me-to-a-long-random-string-min-32-chars

# Repository-usage telemetry (request signals from winget clients). Off by default.
# TELEMETRY_ENABLED=true
# TELEMETRY_RETENTION_DAYS=90

# Scheduled upstream-catalog sync (off by default).
# CATALOG_SYNC_ENABLED=true
# CATALOG_SYNC_INTERVAL_HOURS=6

# Edge-node PKI: CA storage dir and the header the reverse proxy uses to forward the verified
# client certificate (URL-encoded PEM) for node mTLS.
# PKI_DIR=./data/pki
# NODE_CERT_HEADER=x-client-cert
