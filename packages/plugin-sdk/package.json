{
  "name": "@kvellman/plugin-sdk",
  "version": "0.1.0",
  "description": "SDK for building kvellman plugins (Nuxt modules): auth providers, session helpers, entitlement gating",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["kvellman", "plugin", "sdk"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "prepare": "rm -rf dist && tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "h3": "^1"
  },
  "devDependencies": {
    "h3": "^1.15.11",
    "typescript": "^6.0.3"
  }
}
