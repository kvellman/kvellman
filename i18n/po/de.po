msgid "All scopes"
msgstr "Alle Scopes"

msgid "Overlay template"
msgstr "Overlay-Vorlage"

msgid "From version {v}"
msgstr "Aus Version {v}"

msgid "Apply template"
msgstr "Vorlage anwenden"

msgid "New value"
msgstr "Neuer Wert"

msgid "Previous"
msgstr "Vorher"

msgid "Template applied ({n} fields)"
msgstr "Vorlage angewendet ({n} Felder)"

msgid "No installers match the template architectures"
msgstr "Keine Installer passen zu den Architekturen der Vorlage"

msgid "Save as template"
msgstr "Als Vorlage speichern"

msgid "Saved as package template ({n} fields)"
msgstr "Als Paket-Vorlage gespeichert ({n} Felder)"
